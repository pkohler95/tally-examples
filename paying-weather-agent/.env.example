# --- Required ---

# Your Tally API key from the dashboard (test mode prefix tly_test_).
TALLY_API_KEY=

# Provide ONE of these (whichever model you want to use). If both
# are set, the agent prefers Anthropic. To force OpenAI when both
# are set, unset ANTHROPIC_API_KEY for that run.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional ---

# Tally API base URL. Defaults to https://app.tallyforagents.com.
# Set to http://localhost:3000 if running against a local dev server.
# TALLY_BASE_URL=https://app.tallyforagents.com

# Tally agent ID to register / reuse. Defaults to "weather-agent".
# The example will upsert this agent on startup; you must then grant
# it a permission in the dashboard before payments will work.
# TALLY_AGENT_ID=weather-agent

# Mock weather service URL. Defaults to http://localhost:4242 (the
# server.ts in this directory).
# WEATHER_SERVICE_URL=http://localhost:4242

# Service wallet address (where the agent's payment lands). Used by
# the mock server to verify the on-chain transfer. Defaults to the
# Sepolia "junk" address (funds go nowhere, but the verifier still
# checks the on-chain transfer happened). Set to any Sepolia address
# you control if you want to receive the funds.
# WEATHER_SERVICE_WALLET=0x000000000000000000000000000000000000dEaD

# Base Sepolia RPC URL for the verifier. Defaults to the public
# endpoint (https://sepolia.base.org), which is rate-limited. If
# you have an Alchemy or QuickNode key, paste it here.
# BASE_SEPOLIA_RPC_URL=
